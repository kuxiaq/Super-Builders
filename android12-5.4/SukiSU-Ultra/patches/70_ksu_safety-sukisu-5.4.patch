                       const char *type_page, unsigned long flags,
                       void *data_page);
+#else
+#include <linux/uaccess.h>
+static int path_mount(const char *dev_name, struct path *path,
+                      const char *type_page, unsigned long flags,
+                      void *data_page)
+{
+    char buf[384] = { 0 };
+    mm_segment_t old_fs;
